    {
      "id": "jPuMHhfPcV6PwSuPk2yZO",
      "type": "text",
      "x": 2668.258331298828,
      "y": 805,
      "width": 863.4833374023438,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
