    {
      "id": "NKNSXiGkVnoGw0-RR6L7k",
      "type": "text",
      "x": 3605,
      "y": 505,
      "width": 691.8499755859375,
      "height": 495,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
