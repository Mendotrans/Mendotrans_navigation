      "link": null,
      "locked": false,
      "text": "The graph should be serialized to disk at the\nend of this phase so the API server can load\nit into RAM at startup without re-running the\nconstruction pipeline every time.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "cO9_CRe4EmXzcP3IYKEay",
      "originalText": "The graph should be serialized to disk at the end of this phase so the API server can load it into RAM at startup without re-running the construction pipeline every time.",
      "autoResize": true,
      "lineHeight": 1.25
    },
